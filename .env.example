APP_ENV=development
APP_VERSION=1.0.0
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000
FRANKFURTER_BASE=https://api.frankfurter.dev
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=300
MAX_RETRIES=3
RETRY_BACKOFF_SECONDS=0.5
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_COOLDOWN_SECONDS=30
RATE_LIMIT_PER_MINUTE=60
SAMPLE_FX_PATH=./data/sample_fx.json

# API key authentication. Format: name:key,name:key
# Generate a key: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave empty to disable auth (the API will return 401 for /summary in this case).
API_KEYS=dev:dev-key-do-not-use-in-prod
